#!/bin/sh
# Session mouse follows the device in use: off for desktop terminals
# (ghostty/kitty TERM, local or via mosh), on for anything else (Moshi).
# prefix+m sets @mouse_manual, pausing automation until next attach/detach.

DESKTOP_TERMS='xterm-ghostty|xterm-kitty'

is_desktop() {
  echo "$1" | grep -qxE "$DESKTOP_TERMS"
}

set_mouse() {
  if is_desktop "$2"; then
    tmux set-option -t "$1" mouse off
  else
    tmux set-option -t "$1" mouse on
  fi
}

is_manual() {
  [ -n "$(tmux show-options -t "$1" -qv @mouse_manual 2>/dev/null)" ]
}

if [ "$1" = focus ] && [ -n "$2" ] && [ -n "$3" ]; then
  is_manual "$2" && exit 0
  set_mouse "$2" "$3"
  exit 0
fi

# Connection-level recompute: manual overrides reset to automatic
for session in $(tmux list-sessions -F '#{session_id}' 2>/dev/null); do
  tmux set-option -u -t "$session" @mouse_manual 2>/dev/null
  last_term=$(tmux list-clients -t "$session" -F '#{client_activity} #{client_termname}' 2>/dev/null \
    | sort -rn | head -1 | awk '{print $2}')
  if [ -n "$last_term" ]; then
    set_mouse "$session" "$last_term"
  else
    tmux set-option -t "$session" mouse off
  fi
done
