#!/usr/bin/env bash
#
# tmux-safe-split - Guard against splitting panes running code agents
#
# Code agents (Claude Code, Codex, etc.) render heavy UI that causes tmux
# to lag badly when the window is subdivided. This wrapper detects a running
# agent and nudges the user to open a new window instead.

PANE_TTY=$(tmux display-message -p '#{pane_tty}')
TTY_SHORT="${PANE_TTY#/dev/}"

CODE_AGENTS="^(claude|codex|aider)$"

if ps -t "$TTY_SHORT" -o comm= 2>/dev/null | grep -qiE "$CODE_AGENTS"; then
  tmux display-message "Code agent running! Use <prefix>+c to open a new window instead."
else
  tmux split-window "$@"
fi
