#!/bin/sh

# Primary provider: "copilot" or "codex"
# Override with: AI_COMMIT_PROVIDER=codex ai-commit-suggest
DEFAULT_PROVIDER="codex"

DETAILED=0
for arg in "$@"; do
  case "$arg" in
    --detailed|-d) DETAILED=1 ;;
    *) echo "Unknown arg: $arg" >&2; exit 1 ;;
  esac
done

PROVIDER="${AI_COMMIT_PROVIDER:-$DEFAULT_PROVIDER}"

DIFF_EXCLUDES=":!*.lock :!package-lock.json :!yarn.lock :!pnpm-lock.yaml :!go.sum :!Cargo.lock :!composer.lock :!Gemfile.lock :!*.min.js :!*.min.css"

# shellcheck disable=SC2086
DIFF="$(git diff --cached -- . $DIFF_EXCLUDES)"
if [ -z "$DIFF" ]; then
  echo "No staged changes (after excluding lockfiles/minified)." >&2
  exit 1
fi

DIFF_SIZE=${#DIFF}
SIZE_SMALL=81920     # 80 KB
SIZE_MEDIUM=409600   # 400 KB

if [ "$DIFF_SIZE" -le "$SIZE_SMALL" ]; then
  DIFF_SECTION="Full diff:
\`\`\`diff
${DIFF}
\`\`\`"
elif [ "$DIFF_SIZE" -le "$SIZE_MEDIUM" ]; then
  echo "[diff truncated: ${DIFF_SIZE} bytes -> stat + name-status summary]" >&2
  # shellcheck disable=SC2086
  STAT="$(git diff --cached --stat -- . $DIFF_EXCLUDES)"
  # shellcheck disable=SC2086
  NAMES="$(git diff --cached --name-status -- . $DIFF_EXCLUDES)"
  DIFF_SECTION="Diff too large for inline inclusion. File-level summary only.

Stat:
\`\`\`
${STAT}
\`\`\`

Name-status:
\`\`\`
${NAMES}
\`\`\`"
else
  echo "[diff very large: ${DIFF_SIZE} bytes -> name-status only]" >&2
  # shellcheck disable=SC2086
  NAMES="$(git diff --cached --name-status -- . $DIFF_EXCLUDES)"
  NAMES_SIZE=${#NAMES}
  if [ "$NAMES_SIZE" -gt 524288 ]; then
    echo "Diff too large even at name-status level (${NAMES_SIZE} bytes). Please commit in smaller chunks." >&2
    exit 1
  fi
  DIFF_SECTION="Diff extremely large. Only file-level name-status available. Infer intent from paths.

Name-status:
\`\`\`
${NAMES}
\`\`\`"
fi

RECENT_LOGS="$(git log -n 10 --pretty=format:'%h %s' 2>/dev/null || true)"

if [ "$DETAILED" = "1" ]; then
  PROMPT="Write 3 distinct complete git commit messages in conventional commits format for the following changes.

Each candidate must follow this structure exactly:
1. Subject line: \`<type>(<scope>): <short description>\` — max 72 chars, imperative mood, lowercase after colon
2. One blank line
3. Body: explain WHY the change was made and summarize WHAT changed at a high level. Wrap lines at 72 chars. Use short paragraphs or dashes for lists if needed.

Rules:
- Omit scope when not directly relevant
- The body should explain motivation, not restate the diff line by line
- If multiple distinct changes are in the diff, group them logically in the body
- Make the 3 candidates genuinely different (different framings, different emphasis)

Recent commits for style reference:
\`\`\`
${RECENT_LOGS}
\`\`\`

${DIFF_SECTION}

Output format (critical — separator must be on its own line):
<commit message 1>
===COMMIT===
<commit message 2>
===COMMIT===
<commit message 3>

Do NOT put the separator before the first candidate or after the last. No markdown code fences, no preamble, no trailing commentary."
else
  PROMPT="Suggest 10 commit messages for the following changes.

Rules:
- Format: conventional commits \`<type>(<scope>): <description>\`
- Omit scope when not directly relevant
- Abstract to a higher level, don't describe code changes literally
- If multiple changes, capture them all in each message
- Cover diverse scenarios, minimize overlap

Recent commits for style reference:
\`\`\`
${RECENT_LOGS}
\`\`\`

${DIFF_SECTION}

Output ONLY 10 raw commit messages, one per line. No numbers, bullets, or extra text."
fi

run_copilot() {
  gh copilot -- -p "$PROMPT" --silent --allow-all-tools \
    --model claude-sonnet-4.5 2>/dev/null
}

run_codex() {
  OUTFILE="$(mktemp)"
  codex exec "$PROMPT" \
    --sandbox read-only \
    -m gpt-5.4 \
    -c model_reasoning_effort=low \
    -c tools.web_search=false \
    -o "$OUTFILE" >/dev/null 2>&1
  cat "$OUTFILE"
  rm -f "$OUTFILE"
}

case "$PROVIDER" in
  copilot)
    run_copilot || run_codex || { echo "Both providers failed." >&2; exit 1; }
    ;;
  codex)
    run_codex || run_copilot || { echo "Both providers failed." >&2; exit 1; }
    ;;
  *)
    echo "Unknown provider: $PROVIDER (use 'copilot' or 'codex')" >&2
    exit 1
    ;;
esac
