#!/bin/sh

# Provider priority: copilot > claude > gemini > codex
# Override with: AI_COMMIT_PROVIDER=codex ai-commit-suggest
DEFAULT_PROVIDER="copilot"

DETAILED=""
for arg in "$@"; do
  case "$arg" in
  --detailed | -d) DETAILED=1 ;;
  --short | -s) DETAILED=0 ;;
  *)
    echo "Unknown arg: $arg" >&2
    exit 1
    ;;
  esac
done

PROVIDER="${AI_COMMIT_PROVIDER:-$DEFAULT_PROVIDER}"

DIFF_EXCLUDES=":!*.lock :!package-lock.json :!yarn.lock :!pnpm-lock.yaml :!go.sum :!Cargo.lock :!composer.lock :!Gemfile.lock :!*.min.js :!*.min.css"

# shellcheck disable=SC2086
DIFF="$(git diff --cached -- . $DIFF_EXCLUDES)"
if [ -z "$DIFF" ]; then
  echo "No staged changes (after excluding lockfiles/minified)." >&2
  exit 1
fi

if [ -z "$DETAILED" ]; then
  # shellcheck disable=SC2086
  read -r ADDED DELETED <<EOF
$(git diff --cached --numstat -- . $DIFF_EXCLUDES | awk '{a+=$1;d+=$2} END{print a+0, d+0}')
EOF
  EFFECTIVE=$(((ADDED + DELETED) / 2))
  # shellcheck disable=SC2086
  FILE_COUNT=$(git diff --cached --name-only -- . $DIFF_EXCLUDES | wc -l | tr -d ' ')
  if { [ "$FILE_COUNT" -ge 10 ] && [ "$EFFECTIVE" -gt 200 ]; } || [ "$EFFECTIVE" -gt 500 ]; then
    DETAILED=1
    echo "[auto: detailed mode | +${ADDED}/-${DELETED} lines (eff ${EFFECTIVE}) / ${FILE_COUNT} files]" >&2
  else
    DETAILED=0
  fi
fi

DIFF_SIZE=${#DIFF}
SIZE_SMALL=81920   # 80 KB
SIZE_MEDIUM=409600 # 400 KB

if [ "$DIFF_SIZE" -le "$SIZE_SMALL" ]; then
  DIFF_SECTION="Full diff:
\`\`\`diff
${DIFF}
\`\`\`"
elif [ "$DIFF_SIZE" -le "$SIZE_MEDIUM" ]; then
  echo "[diff truncated: ${DIFF_SIZE} bytes -> stat + name-status summary]" >&2
  # shellcheck disable=SC2086
  STAT="$(git diff --cached --stat -- . $DIFF_EXCLUDES)"
  # shellcheck disable=SC2086
  NAMES="$(git diff --cached --name-status -- . $DIFF_EXCLUDES)"
  DIFF_SECTION="Diff too large for inline inclusion. File-level summary only.

Stat:
\`\`\`
${STAT}
\`\`\`

Name-status:
\`\`\`
${NAMES}
\`\`\`"
else
  echo "[diff very large: ${DIFF_SIZE} bytes -> name-status only]" >&2
  # shellcheck disable=SC2086
  NAMES="$(git diff --cached --name-status -- . $DIFF_EXCLUDES)"
  NAMES_SIZE=${#NAMES}
  if [ "$NAMES_SIZE" -gt 524288 ]; then
    echo "Diff too large even at name-status level (${NAMES_SIZE} bytes). Please commit in smaller chunks." >&2
    exit 1
  fi
  DIFF_SECTION="Diff extremely large. Only file-level name-status available. Infer intent from paths.

Name-status:
\`\`\`
${NAMES}
\`\`\`"
fi

RECENT_LOGS="$(git log -n 10 --pretty=format:'%h %s' 2>/dev/null || true)"

if [ "$DETAILED" = "1" ]; then
  PROMPT="Write 5 distinct complete git commit messages in conventional commits format for the following changes.

Each candidate must follow this structure exactly:
1. Subject line: \`<type>(<scope>): <short description>\` — max 72 chars, imperative mood, lowercase after colon
2. One blank line
3. Body: explain WHY the change was made and summarize WHAT changed at a high level. Wrap lines at 72 chars. Use short paragraphs or dashes for lists if needed.

Rules:
- Omit scope when not directly relevant
- The body should explain motivation, not restate the diff line by line
- If multiple distinct changes are in the diff, group them logically in the body
- Make the 5 candidates genuinely different (different framings, different emphasis, different levels of abstraction)

Recent commits for style reference:
\`\`\`
${RECENT_LOGS}
\`\`\`

${DIFF_SECTION}

Output format (critical — separator must be on its own line between every pair of candidates):
<commit message 1>
===COMMIT===
<commit message 2>
===COMMIT===
...
===COMMIT===
<commit message 5>

Do NOT put the separator before the first candidate or after the last. No markdown code fences, no preamble, no trailing commentary."
else
  PROMPT="Suggest 10 commit messages for the following changes.

Rules:
- Format: conventional commits \`<type>(<scope>): <description>\`
- Omit scope when not directly relevant
- Abstract to a higher level, don't describe code changes literally
- If multiple changes, capture them all in each message
- Cover diverse scenarios, minimize overlap

Recent commits for style reference:
\`\`\`
${RECENT_LOGS}
\`\`\`

${DIFF_SECTION}

Output ONLY 10 raw commit messages, one per line. No numbers, bullets, or extra text."
fi

TIMEOUT_SECS=60

wait_with_timer() {
  pid=$1
  label=$2
  tick=0
  while kill -0 "$pid" 2>/dev/null; do
    sleep 0.1
    tick=$((tick + 1))
    elapsed=$(awk "BEGIN{printf \"%.1f\", $tick/10}")
    printf '\r\033[K\033[36m●\033[0m %s %s/%ss' "$label" "$elapsed" "$TIMEOUT_SECS" >&2
    if [ "$tick" -ge $((TIMEOUT_SECS * 10)) ]; then
      kill "$pid" 2>/dev/null
      sleep 0.2
      kill -KILL "$pid" 2>/dev/null
      { wait "$pid"; } 2>/dev/null
      printf '\r\033[K\033[33m●\033[0m %s timeout after %ss\n' "$label" "$TIMEOUT_SECS" >&2
      return 124
    fi
  done
  { wait "$pid"; } 2>/dev/null
  rc=$?
  printf '\r\033[K' >&2
  return "$rc"
}

run_copilot() {
  outfile=$(mktemp)
  errfile=$(mktemp)
  (gh copilot -- -p "$PROMPT" --silent --allow-all-tools \
    --model claude-sonnet-4.6 >"$outfile" 2>"$errfile") &
  pid=$!
  wait_with_timer "$pid" "GitHub Copilot"
  rc=$?
  if [ "$rc" = "0" ] && [ -s "$outfile" ]; then
    cat "$outfile"
    rm -f "$outfile" "$errfile"
    return 0
  fi
  [ -s "$errfile" ] && printf '\033[33mGitHub Copilot failed:\033[0m %s\n' "$(head -5 "$errfile")" >&2
  [ "$rc" = "0" ] && printf '\033[33mGitHub Copilot:\033[0m empty output\n' >&2
  rm -f "$outfile" "$errfile"
  return 1
}

run_codex() {
  outfile=$(mktemp)
  errfile=$(mktemp)
  (codex exec "$PROMPT" \
    --sandbox read-only \
    -m gpt-5.4 \
    -c model_reasoning_effort=low \
    -c tools.web_search=false \
    -o "$outfile" >"$errfile" 2>&1) &
  pid=$!
  wait_with_timer "$pid" "OpenAI Codex"
  rc=$?
  if [ "$rc" = "0" ] && [ -s "$outfile" ]; then
    cat "$outfile"
    rm -f "$outfile" "$errfile"
    return 0
  fi
  [ -s "$errfile" ] && printf '\033[33mOpenAI Codex failed:\033[0m %s\n' "$(head -5 "$errfile")" >&2
  [ "$rc" = "0" ] && printf '\033[33mOpenAI Codex:\033[0m empty output\n' >&2
  rm -f "$outfile" "$errfile"
  return 1
}

run_gemini() {
  outfile=$(mktemp)
  errfile=$(mktemp)
  (gemini -p "$PROMPT" --sandbox \
    -m gemini-2.5-pro \
    >"$outfile" 2>"$errfile") &
  pid=$!
  wait_with_timer "$pid" "Google Gemini"
  rc=$?
  if [ "$rc" = "0" ] && [ -s "$outfile" ]; then
    cat "$outfile"
    rm -f "$outfile" "$errfile"
    return 0
  fi
  [ -s "$errfile" ] && printf '\033[33mGoogle Gemini failed:\033[0m %s\n' "$(head -5 "$errfile")" >&2
  [ "$rc" = "0" ] && printf '\033[33mGoogle Gemini:\033[0m empty output\n' >&2
  rm -f "$outfile" "$errfile"
  return 1
}

run_claude() {
  outfile=$(mktemp)
  errfile=$(mktemp)
  (claude -p "$PROMPT" --bare \
    --model sonnet \
    --allowedTools '' \
    >"$outfile" 2>"$errfile") &
  pid=$!
  wait_with_timer "$pid" "Anthropic Claude Code"
  rc=$?
  if [ "$rc" = "0" ] && [ -s "$outfile" ]; then
    cat "$outfile"
    rm -f "$outfile" "$errfile"
    return 0
  fi
  [ -s "$errfile" ] && printf '\033[33mAnthropic Claude Code failed:\033[0m %s\n' "$(head -5 "$errfile")" >&2
  [ "$rc" = "0" ] && printf '\033[33mAnthropic Claude Code:\033[0m empty output\n' >&2
  rm -f "$outfile" "$errfile"
  return 1
}

provider_label() {
  case "$1" in
    gemini)  echo "Google Gemini"    ;;
    codex)   echo "OpenAI Codex"     ;;
    copilot) echo "GitHub Copilot"   ;;
    claude)  echo "Anthropic Claude Code" ;;
  esac
}

fallback_to() {
  printf '\033[36m↻ falling back to %s…\033[0m\n' "$(provider_label "$1")" >&2
}

PROVIDERS="copilot claude gemini codex"

run_provider() {
  case "$1" in
    gemini)  run_gemini  ;;
    codex)   run_codex   ;;
    copilot) run_copilot ;;
    claude)  run_claude  ;;
    *)       return 1    ;;
  esac
}

case "$PROVIDERS" in
  *"$PROVIDER"*) ;;
  *)
    echo "Unknown provider: $PROVIDER (use one of: $PROVIDERS)" >&2
    exit 1
    ;;
esac

# Build fallback order: chosen provider first, then remaining in priority order
ORDERED="$PROVIDER"
for p in $PROVIDERS; do
  case " $ORDERED " in
    *" $p "*) ;;
    *) ORDERED="$ORDERED $p" ;;
  esac
done

FIRST=1
for p in $ORDERED; do
  if [ "$FIRST" = "1" ]; then
    FIRST=0
    run_provider "$p" && exit 0
  else
    fallback_to "$p"
    run_provider "$p" && exit 0
  fi
done

echo "All providers failed." >&2
exit 1
